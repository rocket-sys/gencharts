{
  "name": "gencharts",
  "version": "1.0.0",
  "description": "Lightweight financial charting library — live data, indicators, drawings, replay. Zero runtime dependencies.",
  "author": "GenTrade",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "chart",
    "candlestick",
    "trading",
    "financial",
    "forex",
    "crypto",
    "OHLCV",
    "indicators",
    "technical-analysis",
    "canvas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/gencharts.git"
  }
}
